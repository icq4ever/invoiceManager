<div class="mb-4">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
    <%= client && client.id ? t('client.edit') : t('client.new') %>
  </h1>
</div>

<% if (error) { %>
<div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4">
  <%= error %>
</div>
<% } %>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-3 sm:p-6">
  <form method="POST" action="<%= client && client.id ? '/clients/' + client.id : '/clients' %>" enctype="multipart/form-data">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('client.name') %> *</label>
        <input type="text" name="name" required value="<%= client?.name || '' %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('client.contact_person') %></label>
        <input type="text" name="contact_person" value="<%= client?.contact_person || '' %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('client.business_number') %></label>
        <input type="text" name="business_number" value="<%= client?.business_number || '' %>" placeholder="000-00-00000"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('client.phone') %></label>
        <input type="text" name="phone" value="<%= client?.phone || '' %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('client.email') %></label>
        <input type="email" name="email" value="<%= client?.email || '' %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('client.address') %></label>
        <input type="text" id="clientAddressInput" name="address" value="<%= (client?.address || '').replace(/\n/g, '\\n') %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="(Shift+Enter)">
      </div>
      <div class="md:col-span-2">
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('client.business_registration') %></label>
        <% if (client?.business_registration_path) { %>
        <div class="mb-2 flex items-center gap-2">
          <% if (client.business_registration_path.endsWith('.pdf')) { %>
            <a href="<%= client.business_registration_path %>" target="_blank" class="text-blue-600 dark:text-blue-400 text-sm hover:underline">📄 PDF <%= t('common.view') %></a>
          <% } else { %>
            <img src="<%= client.business_registration_path %>" alt="Business Registration" class="h-20 rounded border dark:border-gray-600">
          <% } %>
          <label class="flex items-center gap-1 text-xs text-red-500 cursor-pointer">
            <input type="checkbox" name="remove_business_registration" value="1">
            <%= t('common.delete') %>
          </label>
        </div>
        <% } %>
        <input type="file" name="business_registration" accept="image/*,.pdf"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
    </div>

    <script>
      document.getElementById('clientAddressInput').addEventListener('keydown', function(e) {
        if (e.shiftKey && e.key === 'Enter') {
          e.preventDefault();
          const start = this.selectionStart;
          const end = this.selectionEnd;
          const value = this.value;
          this.value = value.substring(0, start) + '\\n' + value.substring(end);
          this.selectionStart = this.selectionEnd = start + 2;
        }
      });
    </script>

    <div class="mt-4 flex justify-end space-x-2">
      <a href="/clients" class="px-4 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700"><%= t('common.cancel') %></a>
      <button type="submit" class="px-4 py-1.5 text-sm bg-blue-600 text-white rounded-md hover:bg-blue-700"><%= t('common.save') %></button>
    </div>
  </form>
</div>
