<div class="mb-4 flex justify-between items-center">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= client.name %></h1>
  <div class="flex gap-2">
    <a href="/clients/<%= client.id %>/edit" class="px-4 py-1.5 text-sm bg-blue-600 text-white rounded-md hover:bg-blue-700"><%= t('common.edit') %></a>
    <a href="/clients" class="px-4 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700"><%= t('client.list') %></a>
  </div>
</div>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 sm:p-6">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="block text-xs text-gray-500 dark:text-gray-400"><%= t('client.name') %></label>
      <p class="text-sm text-gray-900 dark:text-white mt-0.5"><%= client.name || '-' %></p>
    </div>
    <div>
      <label class="block text-xs text-gray-500 dark:text-gray-400"><%= t('client.contact_person') %></label>
      <p class="text-sm text-gray-900 dark:text-white mt-0.5"><%= client.contact_person || '-' %></p>
    </div>
    <div>
      <label class="block text-xs text-gray-500 dark:text-gray-400"><%= t('client.business_number') %></label>
      <p class="text-sm text-gray-900 dark:text-white mt-0.5"><%= client.business_number || '-' %></p>
    </div>
    <div>
      <label class="block text-xs text-gray-500 dark:text-gray-400"><%= t('client.phone') %></label>
      <p class="text-sm text-gray-900 dark:text-white mt-0.5"><%= client.phone || '-' %></p>
    </div>
    <div>
      <label class="block text-xs text-gray-500 dark:text-gray-400"><%= t('client.email') %></label>
      <p class="text-sm text-gray-900 dark:text-white mt-0.5"><%= client.email || '-' %></p>
    </div>
    <div>
      <label class="block text-xs text-gray-500 dark:text-gray-400"><%= t('client.address') %></label>
      <p class="text-sm text-gray-900 dark:text-white mt-0.5"><%= client.address || '-' %></p>
    </div>

    <div class="md:col-span-2">
      <label class="block text-xs text-gray-500 dark:text-gray-400 mb-1"><%= t('client.business_registration') %></label>
      <% if (client.business_registration_path) { %>
        <% if (client.business_registration_path.endsWith('.pdf')) { %>
          <a href="<%= client.business_registration_path %>" target="_blank"
            class="inline-flex items-center gap-1 text-sm text-blue-600 dark:text-blue-400 hover:underline">
            📄 PDF <%= t('client.view_document') %>
          </a>
          <a href="<%= client.business_registration_path %>" download
            class="inline-flex items-center gap-1 text-sm text-gray-600 dark:text-gray-400 hover:underline ml-3">
            <%= t('client.download') %>
          </a>
        <% } else { %>
          <a href="<%= client.business_registration_path %>" target="_blank" class="block">
            <img src="<%= client.business_registration_path %>" alt="<%= t('client.business_registration') %>"
              class="max-w-md max-h-80 rounded border dark:border-gray-600 cursor-pointer hover:opacity-90 transition-opacity">
          </a>
          <a href="<%= client.business_registration_path %>" download
            class="inline-flex items-center gap-1 text-sm text-gray-600 dark:text-gray-400 hover:underline mt-1">
            <%= t('client.download') %>
          </a>
        <% } %>
      <% } else { %>
        <p class="text-sm text-gray-400 dark:text-gray-500">-</p>
      <% } %>
    </div>
  </div>
</div>
