<div class="mb-4">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
    <%= company && company.id ? t('company.edit') : t('company.new') %>
  </h1>
</div>

<% if (error) { %>
<div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4">
  <%= error %>
</div>
<% } %>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-3 sm:p-6">
  <form method="POST" action="<%= company && company.id ? '/companies/' + company.id : '/companies' %>" enctype="multipart/form-data">
    <!-- Tabs -->
    <div class="border-b border-gray-300 dark:border-gray-600 mb-4">
      <div class="flex space-x-6">
        <button type="button" class="tab-button py-2 px-1 border-b-2 border-blue-600 text-blue-600 text-sm font-medium" data-tab="korean" onclick="switchTab(event, 'korean')">
          <%= t('company.korean') %>
        </button>
        <button type="button" class="tab-button py-2 px-1 border-b-2 border-transparent text-gray-600 dark:text-gray-400 text-sm font-medium hover:text-gray-900 dark:hover:text-gray-300" data-tab="english" onclick="switchTab(event, 'english')">
          <%= t('company.english') %>
        </button>
        <button type="button" class="tab-button py-2 px-1 border-b-2 border-transparent text-gray-600 dark:text-gray-400 text-sm font-medium hover:text-gray-900 dark:hover:text-gray-300" data-tab="bank" onclick="switchTab(event, 'bank')">
          <%= t('company.bank_accounts') %>
        </button>
        <button type="button" class="tab-button py-2 px-1 border-b-2 border-transparent text-gray-600 dark:text-gray-400 text-sm font-medium hover:text-gray-900 dark:hover:text-gray-300" data-tab="smtp" onclick="switchTab(event, 'smtp')">
          <%= t('email.smtp_settings') %>
        </button>
      </div>
    </div>

    <!-- Korean Tab -->
    <div id="korean-tab" class="tab-content">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.name') %> *</label>
        <input type="text" name="name" required value="<%= company?.name || '' %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.representative') %></label>
        <input type="text" name="representative" value="<%= company?.representative || '' %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.business_number') %></label>
        <input type="text" name="business_number" value="<%= company?.business_number || '' %>" placeholder="000-00-00000"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.phone') %></label>
        <input type="text" name="phone" value="<%= company?.phone || '' %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.website') %></label>
        <input type="url" name="website" value="<%= company?.website || '' %>" placeholder="https://"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.fax') %></label>
        <input type="text" name="fax" value="<%= company?.fax || '' %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.email') %></label>
        <input type="email" name="email" value="<%= company?.email || '' %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <input type="hidden" name="bank_info" value="<%= company?.bank_info || '' %>">
      <input type="hidden" name="bank_info_en" value="<%= company?.bank_info_en || '' %>">
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.invoice_prefix') %></label>
        <input type="text" name="invoice_prefix" value="<%= company?.invoice_prefix || 'INV' %>" placeholder="INV"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1"><%= t('company.invoice_prefix_help') %></p>
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.address') %></label>
        <input type="text" name="address" id="addressInput" value="<%= company?.address || '' %>"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="(Shift+Enter)">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.logo') %></label>
        <% if (company?.logo_path) { %>
        <div class="mb-2"><img src="<%= company.logo_path %>" alt="Logo" class="h-12 object-contain"></div>
        <% } %>
        <input type="file" name="logo" accept="image/*"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.stamp') %></label>
        <% if (company?.stamp_path) { %>
        <div class="mb-2"><img src="<%= company.stamp_path %>" alt="Stamp" class="h-12 object-contain"></div>
        <% } %>
        <input type="file" name="stamp" accept="image/*"
          class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>
      </div>
    </div>

    <!-- English Tab -->
    <div id="english-tab" class="tab-content" style="display: none;">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.name_en') %></label>
          <input type="text" name="name_en" value="<%= company?.name_en || '' %>"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.representative_en') %></label>
          <input type="text" name="representative_en" value="<%= company?.representative_en || '' %>"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.phone_en') %></label>
          <input type="text" name="phone_en" value="<%= company?.phone_en || '' %>"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.email_en') %></label>
          <input type="email" name="email_en" value="<%= company?.email_en || '' %>"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.address_en') %></label>
          <input type="text" name="address_en" id="addressEnInput" value="<%= company?.address_en || '' %>"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="(Shift+Enter)">
        </div>
      </div>
    </div>

    <!-- Bank Accounts Tab -->
    <div id="bank-tab" class="tab-content" style="display: none;">
      <div id="bankAccountsList">
        <% const accounts = (typeof bankAccounts !== 'undefined' && bankAccounts) ? bankAccounts : []; %>
        <% if (accounts.length === 0) { %>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3" id="noBankMsg"><%= t('company.no_bank_accounts') %></p>
        <% } %>
        <% accounts.forEach(function(ba, idx) { %>
        <div class="bank-account-card border border-gray-300 dark:border-gray-600 rounded-lg p-3 mb-3">
          <div class="flex justify-between items-center mb-2">
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">#<span class="bank-index"><%= idx + 1 %></span></span>
            <button type="button" onclick="removeBankAccount(this)" class="text-xs text-red-600 hover:text-red-800 dark:text-red-400"><%= t('company.remove_bank_account') %></button>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            <div>
              <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.bank_name') %> *</label>
              <input type="text" name="bank_name" value="<%= ba.bank_name || '' %>"
                class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.bank_name_en') %></label>
              <input type="text" name="bank_name_en" value="<%= ba.bank_name_en || '' %>"
                class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.account_number') %> *</label>
              <input type="text" name="account_number" value="<%= ba.account_number || '' %>"
                class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.swift_code') %></label>
              <input type="text" name="swift_code" value="<%= ba.swift_code || '' %>"
                class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.branch') %></label>
              <input type="text" name="branch" value="<%= ba.branch || '' %>"
                class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.branch_en') %></label>
              <input type="text" name="branch_en" value="<%= ba.branch_en || '' %>"
                class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
            </div>
            <div class="md:col-span-2">
              <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.paypal_account') %></label>
              <input type="text" name="paypal_account" value="<%= ba.paypal_account || '' %>" placeholder="email@example.com"
                class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
            </div>
          </div>
          <div class="flex items-center gap-4 mt-2">
            <input type="hidden" name="bank_enabled" value="<%= ba.is_enabled ? '1' : '0' %>">
            <label class="flex items-center">
              <input type="checkbox" class="bank-enabled-cb rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500" <%= ba.is_enabled ? 'checked' : '' %>>
              <span class="ml-1.5 text-xs text-gray-700 dark:text-gray-300"><%= t('company.enabled') %></span>
            </label>
          </div>
        </div>
        <% }); %>
      </div>
      <button type="button" onclick="addBankAccount()" class="px-3 py-1.5 text-sm bg-green-600 text-white rounded-md hover:bg-green-700">
        + <%= t('company.add_bank_account') %>
      </button>
    </div>

    <!-- SMTP Settings Tab -->
    <div id="smtp-tab" class="tab-content" style="display: none;">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('email.smtp_host') %></label>
          <input type="text" name="smtp_host" value="<%= company?.smtp_host || '' %>" placeholder="smtp.gmail.com"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('email.smtp_port') %></label>
          <input type="number" name="smtp_port" id="smtpPort" value="<%= company?.smtp_port || 587 %>" placeholder="587"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('email.smtp_user') %></label>
          <input type="text" name="smtp_user" value="<%= company?.smtp_user || '' %>" placeholder="user@example.com"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('email.smtp_pass') %></label>
          <input type="password" name="smtp_pass" value="<%= company?.smtp_pass || '' %>" placeholder="••••••••"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('email.smtp_from_name') %></label>
          <input type="text" name="smtp_from_name" value="<%= company?.smtp_from_name || '' %>" placeholder="<%= t('email.smtp_from_name_placeholder') %>"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('email.smtp_from_email') %></label>
          <input type="email" name="smtp_from_email" value="<%= company?.smtp_from_email || '' %>" placeholder="noreply@example.com"
            class="w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
        </div>
        <div class="flex items-center">
          <label class="flex items-center">
            <input type="checkbox" name="smtp_secure" id="smtpSecure" value="1" <%= company?.smtp_secure ? 'checked' : '' %> onchange="onSmtpSecureChange(this)"
              class="rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500">
            <span class="ml-2 text-sm text-gray-700 dark:text-gray-300"><%= t('email.smtp_secure') %></span>
          </label>
        </div>
        <div class="flex items-center">
          <button type="button" onclick="testSmtp()" class="px-3 py-1.5 text-sm bg-gray-600 text-white rounded-md hover:bg-gray-700">
            <%= t('email.test_connection') %>
          </button>
          <span id="smtpTestResult" class="ml-2 text-sm"></span>
        </div>
      </div>
      <div class="mt-3 p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
        <p class="text-xs text-gray-500 dark:text-gray-400"><%= t('email.smtp_help') %></p>
        <details class="mt-2">
          <summary class="text-xs font-medium text-blue-600 dark:text-blue-400 cursor-pointer"><%= t('email.gmail_guide_title') %></summary>
          <div class="mt-2 text-xs text-gray-500 dark:text-gray-400 space-y-1">
            <p><strong><%= t('email.gmail_guide_step1') %></strong></p>
            <p><%= t('email.gmail_guide_step2') %></p>
            <p><%= t('email.gmail_guide_step3') %></p>
            <p><%= t('email.gmail_guide_step4') %></p>
            <div class="mt-2 p-2 bg-gray-100 dark:bg-gray-600 rounded text-xs">
              <p>SMTP Host: <code>smtp.gmail.com</code></p>
              <p>SMTP Port: <code>587</code></p>
              <p>SSL/TLS: <code><%= t('email.gmail_guide_ssl_off') %></code></p>
              <p>Username: <code><%= t('email.gmail_guide_username') %></code></p>
              <p>Password: <code><%= t('email.gmail_guide_password') %></code></p>
            </div>
          </div>
        </details>
      </div>
      <% if (company && company.id) { %>
      <div class="mt-4">
        <a href="/email/templates/manage/<%= company.id %>" class="inline-flex items-center px-3 py-1.5 text-sm bg-purple-600 text-white rounded-md hover:bg-purple-700">
          <%= t('email.manage_templates') %>
        </a>
      </div>
      <% } %>
    </div>

    <!-- Common Settings -->
    <div class="md:col-span-2 mt-4">
      <label class="flex items-center">
        <input type="checkbox" name="is_default" value="1" <%= company?.is_default ? 'checked' : '' %>
          class="rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500">
        <span class="ml-2 text-sm text-gray-700 dark:text-gray-300"><%= t('company.is_default') %></span>
      </label>
    </div>

    <div class="mt-4 flex justify-end space-x-2">
      <a href="/companies" class="px-4 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700"><%= t('common.cancel') %></a>
      <button type="submit" class="px-4 py-1.5 text-sm bg-blue-600 text-white rounded-md hover:bg-blue-700"><%= t('common.save') %></button>
    </div>
  </form>
</div>

<script>
  // Tab switching
  function switchTab(event, tab) {
    event.preventDefault();
    document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
    document.getElementById(tab + '-tab').style.display = 'block';

    document.querySelectorAll('.tab-button').forEach(btn => {
      btn.classList.remove('border-blue-600', 'text-blue-600');
      btn.classList.add('border-transparent', 'text-gray-600', 'dark:text-gray-400');
    });
    event.target.classList.add('border-blue-600', 'text-blue-600');
    event.target.classList.remove('border-transparent', 'text-gray-600', 'dark:text-gray-400');
  }

  // Handle Shift+Enter for Korean address
  const addressInput = document.getElementById('addressInput');
  if (addressInput) {
    addressInput.addEventListener('keydown', function(e) {
      if (e.shiftKey && e.key === 'Enter') {
        e.preventDefault();
        const start = this.selectionStart;
        const end = this.selectionEnd;
        const value = this.value;
        this.value = value.substring(0, start) + '\\n' + value.substring(end);
        this.selectionStart = this.selectionEnd = start + 2;
      }
    });
  }

  // Auto-change port when SSL/TLS checkbox is toggled
  function onSmtpSecureChange(checkbox) {
    const portInput = document.getElementById('smtpPort');
    if (!portInput) return;
    const currentPort = parseInt(portInput.value);
    if (checkbox.checked) {
      // SSL enabled: switch to 465 (if currently on 587 or empty)
      if (currentPort === 587 || !currentPort) {
        portInput.value = 465;
      }
    } else {
      // SSL disabled: switch to 587 (if currently on 465)
      if (currentPort === 465) {
        portInput.value = 587;
      }
    }
  }

  // Test SMTP connection using current form values (no save required)
  function testSmtp() {
    const resultEl = document.getElementById('smtpTestResult');
    resultEl.textContent = '<%= t("common.loading") %>';
    resultEl.className = 'ml-2 text-sm text-gray-500';

    // Read current form values
    const form = document.querySelector('form');
    const smtpData = {
      smtp_host: form.querySelector('[name="smtp_host"]').value,
      smtp_port: form.querySelector('[name="smtp_port"]').value,
      smtp_secure: form.querySelector('[name="smtp_secure"]').checked ? '1' : '0',
      smtp_user: form.querySelector('[name="smtp_user"]').value,
      smtp_pass: form.querySelector('[name="smtp_pass"]').value
    };

    const companyId = '<%= company?.id || 0 %>';

    fetch('/email/test-smtp/' + companyId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(smtpData)
    })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          resultEl.textContent = '<%= t("email.test_success") %>';
          resultEl.className = 'ml-2 text-sm text-green-600 dark:text-green-400';
        } else {
          resultEl.textContent = data.error || '<%= t("email.test_failed") %>';
          resultEl.className = 'ml-2 text-sm text-red-600 dark:text-red-400';
        }
      })
      .catch(() => {
        resultEl.textContent = '<%= t("email.test_failed") %>';
        resultEl.className = 'ml-2 text-sm text-red-600 dark:text-red-400';
      });
  }

  // Handle Shift+Enter for English address
  const addressEnInput = document.getElementById('addressEnInput');
  if (addressEnInput) {
    addressEnInput.addEventListener('keydown', function(e) {
      if (e.shiftKey && e.key === 'Enter') {
        e.preventDefault();
        const start = this.selectionStart;
        const end = this.selectionEnd;
        const value = this.value;
        this.value = value.substring(0, start) + '\\n' + value.substring(end);
        this.selectionStart = this.selectionEnd = start + 2;
      }
    });
  }

  // Sync bank checkbox values to hidden inputs on form submit
  function syncCheckboxToHidden(cb) {
    const label = cb.closest('label');
    if (label && label.previousElementSibling && label.previousElementSibling.type === 'hidden') {
      label.previousElementSibling.value = cb.checked ? '1' : '0';
    }
  }

  document.querySelector('form').addEventListener('submit', function() {
    document.querySelectorAll('.bank-account-card').forEach(function(card) {
      card.querySelectorAll('.bank-enabled-cb').forEach(syncCheckboxToHidden);
    });
  });

  // Also sync on checkbox change for immediate feedback
  document.addEventListener('change', function(e) {
    if (e.target.classList.contains('bank-enabled-cb')) {
      syncCheckboxToHidden(e.target);
    }
  });

  // Bank account management
  function addBankAccount() {
    const list = document.getElementById('bankAccountsList');
    const noBankMsg = document.getElementById('noBankMsg');
    if (noBankMsg) noBankMsg.remove();

    const idx = list.querySelectorAll('.bank-account-card').length + 1;
    const inputClass = 'w-full px-2 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500';
    const card = document.createElement('div');
    card.className = 'bank-account-card border border-gray-300 dark:border-gray-600 rounded-lg p-3 mb-3';
    card.innerHTML = `
      <div class="flex justify-between items-center mb-2">
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">#<span class="bank-index">${idx}</span></span>
        <button type="button" onclick="removeBankAccount(this)" class="text-xs text-red-600 hover:text-red-800 dark:text-red-400"><%= t('company.remove_bank_account') %></button>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.bank_name') %> *</label>
          <input type="text" name="bank_name" class="${inputClass}">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.bank_name_en') %></label>
          <input type="text" name="bank_name_en" class="${inputClass}">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.account_number') %> *</label>
          <input type="text" name="account_number" class="${inputClass}">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.swift_code') %></label>
          <input type="text" name="swift_code" class="${inputClass}">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.branch') %></label>
          <input type="text" name="branch" class="${inputClass}">
        </div>
        <div>
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.branch_en') %></label>
          <input type="text" name="branch_en" class="${inputClass}">
        </div>
        <div class="md:col-span-2">
          <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1"><%= t('company.paypal_account') %></label>
          <input type="text" name="paypal_account" placeholder="email@example.com" class="${inputClass}">
        </div>
      </div>
      <div class="flex items-center gap-4 mt-2">
        <input type="hidden" name="bank_enabled" value="1">
        <label class="flex items-center">
          <input type="checkbox" class="bank-enabled-cb rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500" checked>
          <span class="ml-1.5 text-xs text-gray-700 dark:text-gray-300"><%= t('company.enabled') %></span>
        </label>
      </div>
    `;
    list.appendChild(card);
  }

  function removeBankAccount(btn) {
    const card = btn.closest('.bank-account-card');
    card.remove();
    // Re-index remaining cards
    document.querySelectorAll('.bank-account-card .bank-index').forEach(function(el, i) {
      el.textContent = i + 1;
    });
  }
</script>
